<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Disabled</key>
	<false/>
	<key>Label</key>
	<string>local.algo-gateway-watchdog</string>
	<key>ProgramArguments</key>
	<array>
		<string>/Users/huiliang/ibc/gateway_watchdog.sh</string>
	</array>
	<key>StandardErrorPath</key>
	<string>/Users/huiliang/ibc/logs/gateway-watchdog-launchd.log</string>
	<key>StandardOutPath</key>
	<string>/Users/huiliang/ibc/logs/gateway-watchdog-launchd.log</string>
	<!-- Run every 5 minutes; two consecutive failures (~10 min down) trigger a kickstart -->
	<key>StartInterval</key>
	<integer>300</integer>
</dict>
</plist>
